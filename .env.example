# Environment variables for the SvelteKit frontend.
#
# Copy this file to `.env` and fill in any values you want to override.
# `.env` is gitignored.

# GraphQL endpoint of the Keystone backend. Optional: when unset, the app
# falls back to https://api.log.ddev.site/api/graphql in dev and
# https://api.log.football/api/graphql in production builds.
# Useful for pointing a preview deploy or a local override at another backend
# (for deploy previews, set it in the Netlify UI instead).
# PUBLIC_API_URL=https://api.log.ddev.site/api/graphql
